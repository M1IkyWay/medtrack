#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="${SCRIPT_DIR}/.."
cd "$ROOT_DIR"

# Base marketing version (the part before "+") from pubspec.yaml.
VERSION_BASE=$(grep -E '^version:' pubspec.yaml | awk '{print $2}' | cut -d+ -f1)
if [[ -z "${VERSION_BASE:-}" ]]; then
  echo "Could not read base version from pubspec.yaml" >&2
  exit 1
fi

# Build number = current Unix timestamp. It always increases, so App Store
# Connect never rejects an upload for a duplicate or lower build number — no
# manual bumping of the "+N" in pubspec.yaml needed.
BUILD_NUM=$(date +%s)

echo "Building iOS: ${VERSION_BASE}+${BUILD_NUM}"

# Make sure the iOS platform/toolchain is present (no-op if already installed).
if command -v xcodebuild >/dev/null 2>&1; then
  xcodebuild -downloadPlatform iOS || true
fi

ARGS=(--release --build-name "${VERSION_BASE}" --build-number "${BUILD_NUM}")

# If an export config exists, produce a ready-to-upload App Store IPA via CLI.
# Otherwise Flutter just builds the archive, which you distribute from Xcode's
# Organizer (Window > Organizer > Distribute App).
if [[ -f ios/ExportOptions.plist ]]; then
  ARGS+=(--export-options-plist=ios/ExportOptions.plist)
fi

flutter build ipa "${ARGS[@]}"
